<ui:UXML xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" noNamespaceSchemaLocation="../../../../../UIElementsSchema/UIElements.xsd" editor-extension-mode="True">
    <Style src="project://database/Assets/_/Scripts/Editor/UI%20Toolkit/ArrowPresetBuilder.uss?fileID=7433441132597879392&amp;guid=419dc86cf1a835c4da18f927fd4adfa2&amp;type=3#ArrowPresetBuilder"/>
    <ui:VisualElement name="Container" class="container">
        <ui:VisualElement name="Header" class="container__bar container__top-bar">
            <ui:VisualElement name="Folder" class="header__folder" style="justify-content: space-between; flex-grow: 1;">
                <uie:ObjectField label="Folder" allow-scene-objects="false" value="project://database/Assets/Plugins/Sirenix/Odin%20Inspector/Assets?fileID=102900000&amp;guid=52c0fd243c6c01e4d9efa03616b655d5&amp;type=3#Assets" type="UnityEditor.DefaultAsset, UnityEditor.CoreModule" name="DirectoryField" class="header__folder-field"/>
                <ui:VisualElement style="flex-direction: row;">
                    <ui:DropdownField label="" name="SelectField" choices="Selected: undefined" index="0" class="header__folder-dropdown"/>
                </ui:VisualElement>
            </ui:VisualElement>
        </ui:VisualElement>
        <ui:VisualElement name="Main" class="container__main">
            <_.Scripts.Editor.UI_Toolkit.UIToolkitSceneControl/>
        </ui:VisualElement>
        <ui:VisualElement name="Parameters" class="container__parameters">
            <ui:VisualElement name="Main" class="parameters__main">
                <ui:VisualElement style="flex-direction: row; height: 95px;">
                    <ui:VisualElement>
                        <ui:Image source="" uv="0,0,1,0.85" name="OverlapImage" class="parameters__overlap-image" style="padding-top: 10px; padding-right: 10px; padding-bottom: 10px; padding-left: 10px;">
                            <uie:ObjectField label="" allow-scene-objects="false" value="" type="UnityEngine.Texture, UnityEngine.CoreModule" name="OverlapField" class="parameters__overlap-field"/>
                        </ui:Image>
                    </ui:VisualElement>
                    <ui:VisualElement style="flex-grow: 1; margin-left: 15px; justify-content: flex-end;">
                        <ui:Label text="Center" style="-unity-font-style: bold;"/>
                        <ui:Vector2Field label="" name="OverlapCenter" class="parameters__overlap-center"/>
                        <ui:Label text="Scale" style="-unity-font-style: bold; margin-top: 5px;"/>
                        <ui:Vector2Field label="" name="OverlapScale" value="5,5" class="parameters__overlap-scale"/>
                    </ui:VisualElement>
                </ui:VisualElement>
            </ui:VisualElement>
            <ui:Button text="" name="ToggleButton" icon-image="project://database/Assets/UI%20Toolkit/UnityThemes/UnityDefaultRuntimeTheme.tss?fileID=-4521532143779581420&amp;guid=1410846fea164f64a914d6be16cb7723&amp;type=3#arrow-right" class="parameters__toggle" style="margin-top: 0; margin-right: 0; margin-bottom: 0; margin-left: 0; padding-top: 0; padding-right: 0; padding-bottom: 0; padding-left: 0; border-left-width: 0; border-top-left-radius: 0; border-bottom-left-radius: 0;"/>
